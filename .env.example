# Database (SQLite for local dev)
DATABASE_URL="file:./prisma/dev.db"

# Doctor portal login (seeded on npm run db:seed)
DOCTOR_USERNAME=doctor
DOCTOR_PASSWORD=AcuActiv2026!
DOCTOR_NAME="Dr. Shlomi Gavish"
DOCTOR_EMAIL=henryjames3534@gmail.com

# JWT session signing (change in production)
PORTAL_SESSION_SECRET=change-this-to-a-long-random-string

# Optional: cron job auth for automatic session reminders
# POST /api/portal/reminders with header Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Gmail SMTP (required for live emails — without these, emails log to console in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="AcuActiv <your-email@gmail.com>"
CLINIC_NAME=AcuActiv
CHALLENGE_THANK_YOU_SUBJECT=Thank you for completing the AcuActiv Detox Challenge

# Optional webhook for challenge submissions
DETOX_EMAIL_WEBHOOK=

# Auto session scheduling (weekday: 0=Sun … 6=Sat, default Tuesday=2)
PORTAL_DEFAULT_SESSION_WEEKDAY=2
PORTAL_DEFAULT_SESSION_HOUR=10
PORTAL_DEFAULT_SESSION_MINUTE=0
PORTAL_DEFAULT_SESSION_DURATION=60
PORTAL_SESSION_PRICE=150
NEXT_PUBLIC_APP_URL=http://localhost:3002
