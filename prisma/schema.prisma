generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Doctor {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String
  email        String?
  clinicName   String   @default("AcuActiv")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Patient {
  id          String       @id @default(cuid())
  firstName   String
  lastName    String
  email       String       @unique
  phone       String?
  dateOfBirth String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assessments Assessment[]
  sessions    Session[]
  invoices    Invoice[]
}

model Assessment {
  id                String    @id @default(cuid())
  patientId         String
  patient           Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  grandTotal        Int
  maxTotal          Int
  toxicLevelPercent Float
  toxicLevelLabel   String
  packageNumber     Int
  packageSessions   Int
  resultsJson       String
  completedAt         DateTime
  submissionId        String?   @unique
  followUpSentAt      DateTime?
  thankYouEmailSentAt DateTime?
  doctorEmailSentAt   DateTime?
  createdAt           DateTime  @default(now())
  sessions            Session[]

  @@index([patientId, completedAt])
}

model Session {
  id                    String      @id @default(cuid())
  patientId             String
  patient               Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  assessmentId          String?
  assessment            Assessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  sessionIndex          Int?
  scheduledAt           DateTime
  durationMins          Int         @default(60)
  notes                 String?
  status                String      @default("scheduled")
  patientReminderSentAt DateTime?
  doctorReminderSentAt  DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  invoice               Invoice?

  @@index([scheduledAt])
  @@index([patientId])
  @@index([assessmentId])
}

model Invoice {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  sessionId     String?   @unique
  session       Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  invoiceNumber String    @unique
  amount        Float
  description   String
  status        String    @default("pending")
  autoGenerated Boolean   @default(false)
  emailSentAt   DateTime?
  issuedAt      DateTime  @default(now())
  dueAt         DateTime?
  itemsJson     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([patientId])
}
